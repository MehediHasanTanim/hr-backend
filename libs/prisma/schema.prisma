generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions", "relationJoins", "tracing"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

model Company {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String               @db.VarChar(200)
  slug                 String               @unique @db.VarChar(100)
  logoUrl              String?              @db.Text
  timezone             String               @default("UTC") @db.VarChar(50)
  country              String               @db.Char(2)
  currency             String               @default("USD") @db.Char(3)
  fiscalYearStart      Int                  @default(1)
  subscriptionTier     SubscriptionTier     @default(STARTER)
  isActive             Boolean              @default(true)
  trialEndsAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  departments          Department[]
  employees            Employee[]
  roles                Role[]
  leaveTypes           LeaveType[]
  salaryComponents     SalaryComponent[]
  payPeriods           PayPeriod[]
  attendanceSettings   AttendanceSetting?
  ivrExtensions        IvrExtension[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
  notifications        Notification[]
  companySettings      CompanySetting[]
  documentTemplates    DocumentTemplate[]
  holidays             Holiday[]
  shifts               Shift[]
  announcements        Announcement[]
  performanceCycles    PerformanceCycle[]
  recruitmentPipelines RecruitmentPipeline[]
  trainings            Training[]
  expensePolicies      ExpensePolicy[]
  projects             Project[]
  jobTitles            JobTitle[]
  salaryRevisions      SalaryRevision[]
  payrollRuns          PayrollRun[]
  taxBrackets          TaxBracket[]
  shiftAssignments     ShiftAssignment[]
  overtimeRequests     OvertimeRequest[]
  workFromHomeRequests WorkFromHomeRequest[]

  @@index([slug])
  @@index([isActive])
  @@index([deletedAt])
  @@map("companies")
}

model CompanySetting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  key       String   @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId])
  @@map("company_settings")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String           @db.Uuid
  name        String           @db.VarChar(100)
  description String?          @db.Text
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  employees   EmployeeRole[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource String           @db.VarChar(100)
  action   String           @db.VarChar(50)
  scope    PermissionScope  @default(COMPANY)
  roles    RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  grantedAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ApiKey {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String    @db.Uuid
  name       String    @db.VarChar(100)
  keyHash    String    @unique @db.Char(64)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([keyHash])
  @@map("api_keys")
}

model Department {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String       @db.Uuid
  parentId   String?      @db.Uuid
  name       String       @db.VarChar(150)
  code       String       @db.VarChar(20)
  costCenter String?      @db.VarChar(50)
  headId     String?      @db.Uuid
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent     Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children   Department[] @relation("DeptTree")
  employees  Employee[]
  head       Employee?    @relation("DeptHead", fields: [headId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([headId])
  @@index([deletedAt])
  @@map("departments")
}

model Employee {
  id                        String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                 String                        @db.Uuid
  employeeNumber            String                        @db.VarChar(30)
  userId                    String?                       @unique @db.Uuid
  departmentId              String?                       @db.Uuid
  managerId                 String?                       @db.Uuid
  jobTitleId                String?                       @db.Uuid
  employmentType            EmploymentType
  status                    EmployeeStatus                @default(ACTIVE)
  joinedAt                  DateTime                      @db.Date
  probationEndsAt           DateTime?                     @db.Date
  exitedAt                  DateTime?                     @db.Date
  exitReason                String?                       @db.Text
  workEmail                 String                        @db.Citext
  workPhone                 String?                       @db.VarChar(30)
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  deletedAt                 DateTime?
  company                   Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                      User?                         @relation(fields: [userId], references: [id])
  department                Department?                   @relation(fields: [departmentId], references: [id])
  managedDept               Department[]                  @relation("DeptHead")
  manager                   Employee?                     @relation("ReportingLine", fields: [managerId], references: [id])
  directReports             Employee[]                    @relation("ReportingLine")
  jobTitle                  JobTitle?                     @relation(fields: [jobTitleId], references: [id])
  profile                   EmployeeProfile?
  roles                     EmployeeRole[]
  salaryRevisions           SalaryRevision[]
  leaveAllocations          LeaveAllocation[]
  leaveRequests             LeaveRequest[]
  attendanceLogs            AttendanceLog[]
  payslips                  Payslip[]
  documents                 EmployeeDocument[]
  emergencyContacts         EmergencyContact[]
  bankAccounts              BankAccount[]
  ivrExtensions             IvrExtension[]
  performanceReviews        PerformanceReview[]           @relation("Reviewee")
  authoredPerformanceReviews PerformanceReview[]          @relation("Reviewer")
  goals                     Goal[]
  assets                    Asset[]
  expenses                  Expense[]
  trainings                 EmployeeTraining[]
  announcements             AnnouncementAcknowledgement[]
  projectMemberships        ProjectMember[]

  @@unique([companyId, employeeNumber])
  @@unique([companyId, workEmail])
  @@index([companyId])
  @@index([departmentId])
  @@index([managerId])
  @@index([jobTitleId])
  @@index([status])
  @@index([deletedAt])
  @@map("employees")
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique @db.Citext
  passwordHash  String         @db.Text
  firstName     String         @db.VarChar(100)
  lastName      String         @db.VarChar(100)
  avatarUrl     String?        @db.Text
  locale        String         @default("en") @db.VarChar(10)
  isActive      Boolean        @default(true)
  mfaSecret     String?        @db.Text
  mfaEnabled    Boolean        @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  employee      Employee?
  sessions      UserSession[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model UserSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.Char(64)
  ipAddress String    @db.Inet
  userAgent String?   @db.Text
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("user_sessions")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique @db.Char(64)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  replacedBy String?   @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmployeeProfile {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String        @unique @db.Uuid
  dateOfBirth    DateTime?     @db.Date
  gender         Gender?
  nationality    String?       @db.Char(2)
  nationalId     String?       @db.VarChar(50)
  passportNumber String?       @db.VarChar(30)
  passportExpiry DateTime?     @db.Date
  personalEmail  String?       @db.Citext
  personalPhone  String?       @db.VarChar(30)
  address        Json?
  maritalStatus  MaritalStatus?
  taxIdentifier  String?       @db.VarChar(50)
  updatedAt      DateTime      @updatedAt
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

model EmployeeRole {
  employeeId String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  assignedBy String?  @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
  @@map("employee_roles")
}

model JobTitle {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @db.Uuid
  title     String    @db.VarChar(150)
  level     Int?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, title])
  @@index([companyId])
  @@map("job_titles")
}

model EmergencyContact {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @db.Uuid
  name         String   @db.VarChar(150)
  relationship String   @db.VarChar(50)
  phone        String   @db.VarChar(30)
  email        String?  @db.Citext
  isPrimary    Boolean  @default(false)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("emergency_contacts")
}

model BankAccount {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String   @db.Uuid
  accountName   String   @db.VarChar(150)
  accountNumber String   @db.VarChar(50) // stored encrypted at app layer
  routingNumber String?  @db.VarChar(30)
  bankName      String   @db.VarChar(100)
  bankCode      String?  @db.VarChar(30)
  currency      String   @db.Char(3)
  isPrimary     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("bank_accounts")
}

model SalaryComponent {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String               @db.Uuid
  name          String               @db.VarChar(100)
  code          String               @db.VarChar(20)
  type          SalaryComponentType
  calcMethod    CalcMethod           @default(FIXED)
  defaultValue  Decimal?             @db.Decimal(15, 4)
  formula       String?              @db.Text
  isTaxable     Boolean              @default(true)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  revisionLines SalaryRevisionLine[]
  payslipLines  PayslipLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("salary_components")
}

model SalaryRevision {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String               @db.Uuid
  companyId     String               @db.Uuid
  effectiveFrom DateTime             @db.Date
  reason        String?              @db.Text
  approvedById  String?              @db.Uuid
  approvedAt    DateTime?
  createdAt     DateTime             @default(now())
  employee      Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines         SalaryRevisionLine[]

  @@index([employeeId])
  @@index([companyId])
  @@index([effectiveFrom])
  @@map("salary_revisions")
}

model SalaryRevisionLine {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  revisionId        String          @db.Uuid
  salaryComponentId String          @db.Uuid
  amount            Decimal         @db.Decimal(15, 4)
  overrideFormula   String?         @db.Text
  revision          SalaryRevision  @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id])

  @@index([revisionId])
  @@index([salaryComponentId])
  @@map("salary_revision_lines")
}

model PayPeriod {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String          @db.Uuid
  label       String          @db.VarChar(50)
  startDate   DateTime        @db.Date
  endDate     DateTime        @db.Date
  status      PayPeriodStatus @default(OPEN)
  closedAt    DateTime?
  closedById  String?         @db.Uuid
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payslips    Payslip[]
  payrollRuns PayrollRun[]

  @@unique([companyId, startDate, endDate])
  @@index([companyId])
  @@index([status])
  @@map("pay_periods")
}

model PayrollRun {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String           @db.Uuid
  payPeriodId   String           @db.Uuid
  initiatedById String           @db.Uuid
  status        PayrollRunStatus @default(PENDING)
  totalGross    Decimal          @db.Decimal(15, 2)
  totalNet      Decimal          @db.Decimal(15, 2)
  totalTax      Decimal          @db.Decimal(15, 2)
  processedAt   DateTime?
  errorLog      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payPeriod     PayPeriod        @relation(fields: [payPeriodId], references: [id])

  @@index([companyId])
  @@index([payPeriodId])
  @@index([status])
  @@map("payroll_runs")
}

model Payslip {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String        @db.Uuid
  employeeId  String        @db.Uuid
  payPeriodId String        @db.Uuid
  grossAmount Decimal       @db.Decimal(15, 2)
  netAmount   Decimal       @db.Decimal(15, 2)
  taxAmount   Decimal       @db.Decimal(15, 2)
  status      PayslipStatus @default(DRAFT)
  publishedAt DateTime?
  pdfUrl      String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payPeriod   PayPeriod     @relation(fields: [payPeriodId], references: [id])
  lines       PayslipLine[]

  @@unique([employeeId, payPeriodId])
  @@index([companyId])
  @@index([employeeId])
  @@index([payPeriodId])
  @@index([status])
  @@map("payslips")
}

model PayslipLine {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipId         String          @db.Uuid
  salaryComponentId String          @db.Uuid
  amount            Decimal         @db.Decimal(15, 4)
  note              String?         @db.Text
  payslip           Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id])

  @@index([payslipId])
  @@index([salaryComponentId])
  @@map("payslip_lines")
}

model TaxBracket {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  country   String   @db.Char(2)
  taxYear   Int
  minAmount Decimal  @db.Decimal(15, 2)
  maxAmount Decimal? @db.Decimal(15, 2)
  rate      Decimal  @db.Decimal(6, 4)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, taxYear])
  @@map("tax_brackets")
}

model ExpensePolicy {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String    @db.Uuid
  name            String    @db.VarChar(100)
  maxAmount       Decimal?  @db.Decimal(15, 2)
  requiresReceipt Boolean   @default(true)
  approvalFlow    Json
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses        Expense[]

  @@index([companyId])
  @@map("expense_policies")
}

model Expense {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String         @db.Uuid
  employeeId      String         @db.Uuid
  policyId        String?        @db.Uuid
  category        String         @db.VarChar(80)
  amount          Decimal        @db.Decimal(15, 2)
  currency        String         @db.Char(3)
  description     String?        @db.Text
  receiptUrl      String?        @db.Text
  status          ExpenseStatus  @default(PENDING)
  submittedAt     DateTime       @default(now())
  reviewedAt      DateTime?
  reviewedById    String?        @db.Uuid
  rejectionReason String?        @db.Text
  updatedAt       DateTime       @updatedAt
  employee        Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy          ExpensePolicy? @relation(fields: [policyId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([policyId])
  @@index([status])
  @@map("expenses")
}

model LeaveType {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String            @db.Uuid
  name             String            @db.VarChar(100)
  code             String            @db.VarChar(20)
  isPaid           Boolean           @default(true)
  allowHalfDay     Boolean           @default(true)
  requiresApproval Boolean           @default(true)
  carryForward     Boolean           @default(false)
  maxCarryForward  Int?
  accrualPolicy    Json?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  allocations      LeaveAllocation[]
  requests         LeaveRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("leave_types")
}

model LeaveAllocation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @db.Uuid
  employeeId  String    @db.Uuid
  leaveTypeId String    @db.Uuid
  year        Int
  totalDays   Decimal   @db.Decimal(6, 1)
  usedDays    Decimal   @default(0) @db.Decimal(6, 1)
  carriedOver Decimal   @default(0) @db.Decimal(6, 1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([companyId])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@map("leave_allocations")
}

model LeaveRequest {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String              @db.Uuid
  employeeId      String              @db.Uuid
  leaveTypeId     String              @db.Uuid
  startDate       DateTime            @db.Date
  endDate         DateTime            @db.Date
  totalDays       Decimal             @db.Decimal(6, 1)
  isHalfDay       Boolean             @default(false)
  halfDayPart     HalfDayPart?
  reason          String?             @db.Text
  status          LeaveStatus         @default(PENDING)
  reviewedById    String?             @db.Uuid
  reviewedAt      DateTime?
  rejectionReason String?             @db.Text
  cancelledAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  employee        Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType       LeaveType           @relation(fields: [leaveTypeId], references: [id])
  approvalSteps   LeaveApprovalStep[]

  @@index([companyId])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveApprovalStep {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaveRequestId String         @db.Uuid
  stepNumber     Int
  approverId     String         @db.Uuid
  status         ApprovalStatus @default(PENDING)
  comment        String?        @db.Text
  actionedAt     DateTime?
  leaveRequest   LeaveRequest   @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@index([leaveRequestId])
  @@index([approverId])
  @@map("leave_approval_steps")
}

model Holiday {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String      @db.Uuid
  name        String      @db.VarChar(100)
  date        DateTime    @db.Date
  type        HolidayType @default(PUBLIC)
  country     String?     @db.Char(2)
  isRecurring Boolean     @default(true)
  createdAt   DateTime    @default(now())
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@map("holidays")
}

model Shift {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String            @db.Uuid
  name         String            @db.VarChar(100)
  startTime    String            @db.VarChar(5)
  endTime      String            @db.VarChar(5)
  breakMinutes Int               @default(0)
  workDays     Int[]
  isNightShift Boolean           @default(false)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments  ShiftAssignment[]

  @@index([companyId])
  @@map("shifts")
}

model ShiftAssignment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String   @db.Uuid
  employeeId    String   @db.Uuid
  shiftId       String   @db.Uuid
  effectiveFrom DateTime @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shift         Shift    @relation(fields: [shiftId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([shiftId])
  @@index([effectiveFrom])
  @@map("shift_assignments")
}

model AttendanceSetting {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String   @unique @db.Uuid
  graceMinutes       Int      @default(0)
