generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions", "relationJoins", "tracing"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

model Company {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                @db.VarChar(200)
  slug                 String                @unique @db.VarChar(100)
  logoUrl              String?               @db.Text
  timezone             String                @default("UTC") @db.VarChar(50)
  country              String                @db.Char(2)
  currency             String                @default("USD") @db.Char(3)
  fiscalYearStart      Int                   @default(1)
  subscriptionTier     SubscriptionTier      @default(STARTER)
  isActive             Boolean               @default(true)
  trialEndsAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  departments          Department[]
  employees            Employee[]
  roles                Role[]
  leaveTypes           LeaveType[]
  salaryComponents     SalaryComponent[]
  payPeriods           PayPeriod[]
  attendanceSettings   AttendanceSetting?
  ivrExtensions        IvrExtension[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
  notifications        Notification[]
  companySettings      CompanySetting[]
  documentTemplates    DocumentTemplate[]
  holidayCalendars     HolidayCalendar[]
  shifts               Shift[]
  locations            Location[]
  announcements        Announcement[]
  performanceCycles    PerformanceCycle[]
  recruitmentPipelines RecruitmentPipeline[]
  trainings            Training[]
  expensePolicies      ExpensePolicy[]
  projects             Project[]
  jobTitles            JobTitle[]
  payGrades            PayGrade[]
  bulkImportJobs       BulkImportJob[]
  salaryRevisions      SalaryRevision[]
  salaryStructures     SalaryStructure[]
  employeeSalaries     EmployeeSalary[]
  accrualRunLogs       AccrualRunLog[]
  payrollRuns          PayrollRun[]
  payrollCycles        PayrollCycle[]
  taxBrackets          TaxBracket[]
  shiftAssignments     ShiftAssignment[]
  overtimeRequests     OvertimeRequest[]
  workFromHomeRequests WorkFromHomeRequest[]
  policies             Policy[]
  policyAcknowledgements PolicyAcknowledgement[]
  esignRequests        EsignRequest[]

  @@index([slug])
  @@index([isActive])
  @@index([deletedAt])
  @@map("companies")
}

model CompanySetting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  key       String   @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId])
  @@map("company_settings")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String           @db.Uuid
  name        String           @db.VarChar(100)
  description String?          @db.Text
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  employees   EmployeeRole[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource String           @db.VarChar(100)
  action   String           @db.VarChar(50)
  scope    PermissionScope  @default(COMPANY)
  roles    RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  grantedAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ApiKey {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String    @db.Uuid
  name       String    @db.VarChar(100)
  keyHash    String    @unique @db.Char(64)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([keyHash])
  @@map("api_keys")
}

model Department {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String       @db.Uuid
  parentId   String?      @db.Uuid
  name       String       @db.VarChar(150)
  code       String       @db.VarChar(20)
  costCenter String?      @db.VarChar(50)
  headId     String?      @db.Uuid
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent     Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children   Department[] @relation("DeptTree")
  employees  Employee[]
  head       Employee?    @relation("DeptHead", fields: [headId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([headId])
  @@index([deletedAt])
  @@map("departments")
}

model Employee {
  id                         String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                  String                        @db.Uuid
  employeeNumber             String                        @db.VarChar(30)
  userId                     String?                       @unique @db.Uuid
  departmentId               String?                       @db.Uuid
  managerId                  String?                       @db.Uuid
  jobTitleId                 String?                       @db.Uuid
  locationId                 String?                       @db.Uuid
  payGradeId                 String?                       @db.Uuid
  employmentType             EmploymentType
  status                     EmployeeStatus                @default(ACTIVE)
  joinedAt                   DateTime                      @db.Date
  probationEndsAt            DateTime?                     @db.Date
  exitedAt                   DateTime?                     @db.Date
  lastWorkingDate            DateTime?                     @db.Date
  exitReason                 String?                       @db.Text
  workEmail                  String                        @db.Citext
  workPhone                  String?                       @db.VarChar(30)
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt
  deletedAt                  DateTime?
  company                    Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                       User?                         @relation(fields: [userId], references: [id])
  department                 Department?                   @relation(fields: [departmentId], references: [id])
  managedDept                Department[]                  @relation("DeptHead")
  manager                    Employee?                     @relation("ReportingLine", fields: [managerId], references: [id])
  directReports              Employee[]                    @relation("ReportingLine")
  jobTitle                   JobTitle?                     @relation(fields: [jobTitleId], references: [id])
  location                   Location?                     @relation(fields: [locationId], references: [id])
  payGrade                   PayGrade?                     @relation(fields: [payGradeId], references: [id])
  profile                    EmployeeProfile?
  employmentHistory          EmploymentHistory[]
  addresses                  EmployeeAddress[]
  roles                      EmployeeRole[]
  salaryRevisions            SalaryRevision[]
  leaveBalances              LeaveBalance[]
  leaveRequests              LeaveRequest[]
  attendanceLogs             AttendanceLog[]
  payslips                   Payslip[]
  documents                  EmployeeDocument[]
  emergencyContacts          EmergencyContact[]
  bankAccounts               BankAccount[]
  ivrExtensions              IvrExtension[]
  performanceReviews         PerformanceReview[]           @relation("Reviewee")
  authoredPerformanceReviews PerformanceReview[]           @relation("Reviewer")
  goals                      Goal[]
  assets                     Asset[]
  expenses                   Expense[]
  trainings                  EmployeeTraining[]
  announcements              AnnouncementAcknowledgement[]
  projectMemberships         ProjectMember[]
  correctedAttendances      AttendanceLog[]          @relation("CorrectedAttendance")
  employeeSalaries          EmployeeSalary[]
  bankDetails               EmployeeBankDetail[]
  payrollEntries            PayrollEntry[]
  policyAcknowledgements  PolicyAcknowledgement[]
  esignRequestsAsSigner   EsignRequest[]           @relation("EsignSigner")

  @@unique([companyId, employeeNumber])
  @@unique([companyId, workEmail])
  @@index([companyId])
  @@index([departmentId])
  @@index([managerId])
  @@index([jobTitleId])
  @@index([locationId])
  @@index([payGradeId])
  @@index([status])
  @@index([deletedAt])
  @@map("employees")
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique @db.Citext
  passwordHash  String         @db.Text
  firstName     String         @db.VarChar(100)
  lastName      String         @db.VarChar(100)
  avatarUrl     String?        @db.Text
  locale        String         @default("en") @db.VarChar(10)
  isActive      Boolean        @default(true)
  mfaSecret     String?        @db.Text
  mfaEnabled    Boolean        @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  employee      Employee?
  sessions      UserSession[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model UserSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.Char(64)
  ipAddress String    @db.Inet
  userAgent String?   @db.Text
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("user_sessions")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique @db.Char(64)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  replacedBy String?   @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmployeeProfile {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String         @unique @db.Uuid
  dateOfBirth    DateTime?      @db.Date
  gender         Gender?
  nationality    String?        @db.Char(2)
  nationalId     Json?
  passportNumber Json?
  passportExpiry DateTime?      @db.Date
  personalEmail  String?        @db.Citext
  personalPhone  String?        @db.VarChar(30)
  address        Json?
  maritalStatus  MaritalStatus?
  taxIdentifier  String?        @db.VarChar(50)
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

model Location {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String     @db.Uuid
  name      String     @db.VarChar(150)
  code      String     @db.VarChar(30)
  address   Json?
  timezone  String?    @db.VarChar(50)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([deletedAt])
  @@map("locations")
}

model PayGrade {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String     @db.Uuid
  name      String     @db.VarChar(100)
  code      String     @db.VarChar(30)
  minSalary Decimal?   @db.Decimal(15, 2)
  maxSalary Decimal?   @db.Decimal(15, 2)
  currency  String     @default("USD") @db.Char(3)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([deletedAt])
  @@map("pay_grades")
}

model EmploymentHistory {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String                @db.Uuid
  employeeId    String                @db.Uuid
  eventType     EmploymentHistoryType
  effectiveDate DateTime              @db.Date
  departmentId  String?               @db.Uuid
  jobTitleId    String?               @db.Uuid
  payGradeId    String?               @db.Uuid
  locationId    String?               @db.Uuid
  managerId     String?               @db.Uuid
  notes         String?               @db.Text
  metadata      Json?
  createdById   String?               @db.Uuid
  createdAt     DateTime              @default(now())
  employee      Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([eventType])
  @@index([effectiveDate])
  @@map("employment_history")
}

model EmployeeAddress {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String      @db.Uuid
  type       AddressType @default(HOME)
  line1      String      @db.VarChar(200)
  line2      String?     @db.VarChar(200)
  city       String      @db.VarChar(100)
  state      String?     @db.VarChar(100)
  postalCode String?     @db.VarChar(30)
  country    String      @db.Char(2)
  isPrimary  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([deletedAt])
  @@map("employee_addresses")
}

model EmployeeRole {
  employeeId String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  assignedBy String?  @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
  @@map("employee_roles")
}

model JobTitle {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String     @db.Uuid
  title     String     @db.VarChar(150)
  code      String?    @db.VarChar(30)
  level     Int?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, title])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([deletedAt])
  @@map("job_titles")
}

model EmergencyContact {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String    @db.Uuid
  name         String    @db.VarChar(150)
  relationship String    @db.VarChar(50)
  phone        String    @db.VarChar(30)
  email        String?   @db.Citext
  isPrimary    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([deletedAt])
  @@map("emergency_contacts")
}

model BankAccount {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String    @db.Uuid
  accountName   String    @db.VarChar(150)
  accountNumber Json
  routingNumber String?   @db.VarChar(30)
  bankName      String    @db.VarChar(100)
  bankCode      String?   @db.VarChar(30)
  currency      String    @db.Char(3)
  isPrimary     Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([deletedAt])
  @@map("bank_accounts")
}

model SalaryComponent {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String               @db.Uuid
  name          String               @db.VarChar(100)
  code          String               @db.VarChar(20)
  type          SalaryComponentType
  calcMethod    CalcMethod           @default(FIXED)
  defaultValue  Decimal?             @db.Decimal(15, 4)
  formula       String?              @db.Text
  isTaxable     Boolean              @default(true)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  revisionLines SalaryRevisionLine[]
  payslipLines  PayslipLine[]
  structureLinks  SalaryStructureComponent[]
  entryComponents PayrollEntryComponent[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("salary_components")
}

model SalaryRevision {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String               @db.Uuid
  companyId     String               @db.Uuid
  effectiveFrom DateTime             @db.Date
  reason        String?              @db.Text
  approvedById  String?              @db.Uuid
  approvedAt    DateTime?
  createdAt     DateTime             @default(now())
  employee      Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines         SalaryRevisionLine[]

  @@index([employeeId])
  @@index([companyId])
  @@index([effectiveFrom])
  @@map("salary_revisions")
}

model SalaryRevisionLine {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  revisionId        String          @db.Uuid
  salaryComponentId String          @db.Uuid
  amount            Decimal         @db.Decimal(15, 4)
  overrideFormula   String?         @db.Text
  revision          SalaryRevision  @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id])

  @@index([revisionId])
  @@index([salaryComponentId])
  @@map("salary_revision_lines")
}

model PayPeriod {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String          @db.Uuid
  label       String          @db.VarChar(50)
  startDate   DateTime        @db.Date
  endDate     DateTime        @db.Date
  status      PayPeriodStatus @default(OPEN)
  closedAt    DateTime?
  closedById  String?         @db.Uuid
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payslips    Payslip[]
  payrollRuns PayrollRun[]

  @@unique([companyId, startDate, endDate])
  @@index([companyId])
  @@index([status])
  @@map("pay_periods")
}

model PayrollRun {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String           @db.Uuid
  payPeriodId   String           @db.Uuid
  initiatedById String           @db.Uuid
  status        PayrollRunStatus @default(PENDING)
  totalGross    Decimal          @db.Decimal(15, 2)
  totalNet      Decimal          @db.Decimal(15, 2)
  totalTax      Decimal          @db.Decimal(15, 2)
  processedAt   DateTime?
  errorLog      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payPeriod     PayPeriod        @relation(fields: [payPeriodId], references: [id])

  @@index([companyId])
  @@index([payPeriodId])
  @@index([status])
  @@map("payroll_runs")
}

model Payslip {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String        @db.Uuid
  employeeId  String        @db.Uuid
  payPeriodId String?       @db.Uuid
  cycleId     String?       @db.Uuid
  entryId     String?       @db.Uuid
  grossAmount Decimal       @db.Decimal(15, 2)
  netAmount   Decimal       @db.Decimal(15, 2)
  taxAmount   Decimal       @db.Decimal(15, 2)
  status      PayslipStatus @default(DRAFT)
  publishedAt DateTime?
  pdfUrl      String?       @db.Text
  s3Key       String?       @db.Text
  s3Bucket    String?       @db.Text
  generatedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payPeriod   PayPeriod?    @relation(fields: [payPeriodId], references: [id])
  cycle       PayrollCycle? @relation(fields: [cycleId], references: [id])
  lines       PayslipLine[]

  @@unique([employeeId, payPeriodId])
  @@index([companyId])
  @@index([employeeId])
  @@index([payPeriodId])
  @@index([cycleId])
  @@index([status])
  @@map("payslips")
}

model PayslipLine {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipId         String          @db.Uuid
  salaryComponentId String          @db.Uuid
  amount            Decimal         @db.Decimal(15, 4)
  note              String?         @db.Text
  payslip           Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id])

  @@index([payslipId])
  @@index([salaryComponentId])
  @@map("payslip_lines")
}

model TaxBracket {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  country   String   @db.Char(2)
  taxYear   Int
  minAmount Decimal  @db.Decimal(15, 2)
  maxAmount Decimal? @db.Decimal(15, 2)
  rate      Decimal  @db.Decimal(6, 4)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, taxYear])
  @@map("tax_brackets")
}

// ===== Payroll Module - Sprint 4 =====

model SalaryStructure {
  id          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String                        @db.Uuid
  name        String                        @db.VarChar(100)
  description String?                       @db.Text
  isActive    Boolean                       @default(true)
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  company     Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  components  SalaryStructureComponent[]
  employees   EmployeeSalary[]
  entries     PayrollEntry[]

  @@index([companyId])
  @@map("salary_structures")
}

model SalaryStructureComponent {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  structureId   String            @db.Uuid
  componentId   String            @db.Uuid
  sortOrder     Int               @default(0)
  defaultValue  Decimal           @default(0) @db.Decimal(12, 2)
  structure     SalaryStructure   @relation(fields: [structureId], references: [id], onDelete: Cascade)
  component     SalaryComponent   @relation(fields: [componentId], references: [id])

  @@unique([structureId, componentId])
  @@index([structureId])
  @@index([componentId])
  @@map("salary_structure_components")
}

model EmployeeSalary {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String          @db.Uuid
  structureId   String          @db.Uuid
  companyId     String          @db.Uuid
  ctc           Decimal         @db.Decimal(14, 2)
  effectiveFrom DateTime        @db.Date
  effectiveTo   DateTime?       @db.Date
  status        SalaryStatus    @default(DRAFT)
  notes         String?         @db.Text
  revisedById   String?         @db.Uuid
  approvedById  String?         @db.Uuid
  approvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  structure     SalaryStructure @relation(fields: [structureId], references: [id])
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
