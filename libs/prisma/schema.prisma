  declineReason       String?     @db.Text
  expiresAt           DateTime    @db.Timestamptz
  signedAt            DateTime?   @db.Timestamptz
  declinedAt          DateTime?   @db.Timestamptz
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  company             Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document            EmployeeDocument @relation(fields: [documentId], references: [id])
  signer              Employee    @relation("EsignSigner", fields: [signerEmployeeId], references: [id])

  @@index([companyId])
  @@index([signerEmployeeId, status])
  @@index([documentId, status])
  @@index([expiresAt])
  @@map("esign_requests")
}

