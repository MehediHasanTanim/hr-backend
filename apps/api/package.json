{
  "name": "@hr/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --import ./dist/telemetry/otel.js dist/main.js",
    "start:dev": "tsx --import ./src/telemetry/otel.ts src/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root ../.. --config vitest.config.ts --passWithNoTests apps/api/src/modules/auth",
    "test:watch": "vitest --root ../.. --config vitest.config.ts --passWithNoTests apps/api/src/modules/auth",
    "test:coverage": "vitest run --root ../.. --config vitest.config.ts --coverage --passWithNoTests apps/api/src/modules/auth libs/prisma/src/extensions/__tests__/tenant-scope.spec.ts",
    "test:regression": "vitest run --config src/__tests__/vitest.integration.config.ts",
    "test:regression:watch": "vitest --config src/__tests__/vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/lib-storage": "^3.1075.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@hr/prisma": "workspace:*",
    "@hr/shared": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.4.1",
    "nestjs-throttler-storage-redis": "^0.5.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino-pretty": "^11.2.2",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "fastify": "^5.5.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.6",
    "vitest": "^2.1.9"
  }
}
